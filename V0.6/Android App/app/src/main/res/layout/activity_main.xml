<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HMD Teleprompter Controller"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"
                android:layout_gravity="center_horizontal"
                android:textAlignment="center"/>

            <!-- Bluetooth Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvBtStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bluetooth Status: Disconnected"
                        android:textColor="@android:color/holo_red_dark"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnConnectBt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CONNECT TO BLUETOOTH DEVICE"
                        android:padding="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Input Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/etManualInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Type manual message..."
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnSendManual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Send Manual Text"
                        android:layout_marginBottom="16dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@android:color/darker_gray"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnVoiceInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Continuous Voice"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchOfflineStt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Offline Voice Mode" />

                    <TextView
                        android:id="@+id/tvTranscript"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Real-time transcript will appear here..."
                        android:textStyle="italic" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Translation Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Input Language:"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <Spinner
                        android:id="@+id/spinnerSourceLang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:minHeight="48dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEnableTranslation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Translation"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target Language (Output):"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"/>

                    <Spinner
                        android:id="@+id/spinnerTargetLang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:minHeight="48dp"/>

                    <Button
                        android:id="@+id/btnManageModels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manage Language Packs"
                        android:layout_marginBottom="8dp"/>

                    <ProgressBar
                        android:id="@+id/pbDownload"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvTranslation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Translation will stream here..."
                        android:textColor="@android:color/holo_blue_dark" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>